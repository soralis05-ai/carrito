# ============================================
# CONFIGURACIÓN MYSQL PARA DESARROLLO
# ============================================
# 1. Instalar MySQL Community Server desde:
#    https://dev.mysql.com/downloads/installer/
#
# 2. Durante la instalación:
#    - Tipo: Development Machine
#    - Puerto: 3306
#    - Root Password: root123 (o la que elijas)
#
# 3. Iniciar MySQL Workbench y crear database:
#    CREATE DATABASE almapunt_dev CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#
# 4. Copiar este archivo a .env y ajustar valores
# ============================================

# MySQL Configuration
MYSQL_USER=root
MYSQL_PASSWORD=root123
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=almapunt_dev

# Flask Configuration
SECRET_KEY=devkey-secret-change-in-production
DOMAIN=almapunt.es
LOG_LEVEL=DEBUG
