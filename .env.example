# Variables de Entorno para Desarrollo
# Copia este archivo a .env y ajusta los valores

# Clave secreta para Flask (generar una única para producción)
SECRET_KEY=tu_clave_secreta_muy_segura_cambiala_en_produccion

# Dominio del sitio
DOMAIN=almapunt.com

# Ruta del logo (opcional)
# LOGO_PATH=/static/img/brand/logo.png

# Configuración de base de datos (opcional, por defecto usa SQLite)
# DATABASE_URL=sqlite:///app.db

# Email (para futura integración)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu@email.com
# MAIL_PASSWORD=tu_password
